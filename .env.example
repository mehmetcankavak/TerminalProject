# ============================
# CryptoTerminal Configuration
# .env.example — Gerçek değerleri .env dosyasına kopyalayıp gir
# JWT_SECRET üretmek: python -c "import secrets; print(secrets.token_hex(32))"
# ============================

# ── Exchange ─────────────────────────────────────────────────────
EXCHANGE=binance
EXCHANGE_API_KEY=           # Binance API key (read+trade izinli)
EXCHANGE_API_SECRET=        # Binance API secret
EXCHANGE_TESTNET=false

# ── Trading Mode ─────────────────────────────────────────────────
TRADING_MODE=paper          # paper | binance | hyperliquid

# ── Hyperliquid ──────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=    # 0x... EVM private key
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_TESTNET=false

# ── Watchlist ────────────────────────────────────────────────────
WATCHLIST_RAW=BTCUSDT,ETHUSDT,SOLUSDT,XRPUSDT

# ── Haberler ─────────────────────────────────────────────────────
NEWS_SOURCES=cryptopanic,rss
CRYPTOPANIC_API_KEY=
CRYPTOPANIC_FILTER=rising
RSS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/
TWITTER_ACCOUNTS=
TWITTER_BEARER_TOKEN=

# ── Risk ─────────────────────────────────────────────────────────
RISK_MAX_TRADE_USD=100000
RISK_MAX_DAILY_LOSS_PCT=3.0
RISK_MAX_OPEN_POSITIONS=10
RISK_MAX_LEVERAGE=20
RISK_MAX_POSITION_USD=50000
RISK_COOLDOWN_SECONDS=5
RISK_PANIC_COOLDOWN_SECONDS=300
RISK_DUPLICATE_WINDOW_SECONDS=5
RISK_STALE_DATA_MAX_AGE_SECONDS=3
RISK_MAX_SPREAD_PCT=0.5
RISK_NEWS_DELAY_SECONDS=3
RISK_SL_REQUIRED=false

# ── Paper Trading ────────────────────────────────────────────────
PAPER_STARTING_BALANCE=10000.0

# ── Loglama ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/terminal.log

# ── Veritabanı ───────────────────────────────────────────────────
DB_PATH=data/terminal.db
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5433/cryptoterminal

# ── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6380/0

# ── Volume Spike ─────────────────────────────────────────────────
VOLUME_SPIKE_MULTIPLIER=2.0

# ── Auth / JWT ── ZORUNLU ────────────────────────────────────────
# Üret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=                 # ZORUNLU — boş bırakma!
JWT_ALGORITHM=HS256
ADMIN_EMAIL=
PLAN_PRICE_USD=29.0

# ── Coinglass ────────────────────────────────────────────────────
COINGLASS_API_KEY=

# ── Groq AI ──────────────────────────────────────────────────────
GROQ_API_KEY=               # console.groq.com (ücretsiz)

# ── Stripe (legacy) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=          # sk_live_... veya sk_test_...
STRIPE_WEBHOOK_SECRET=      # whsec_...
STRIPE_PRO_PRICE_ID=        # price_...

# ── Crypto Payment — Wallet Addresses ────────────────────────────
WALLET_ERC20=               # 0x... Ethereum mainnet
WALLET_BSC=                 # 0x... BSC (BEP-20)
WALLET_SOLANA=              # So1... Solana (SPL)
WALLET_TRON=                # T...  Tron (TRC-20)
WALLET_ARBITRUM=            # 0x... Arbitrum One

# ── Crypto Payment — Plan Prices ─────────────────────────────────
PLAN_PRICE_MONTHLY=29.0
PLAN_PRICE_YEARLY=249.0

# ── Email / SMTP ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=              # Gmail App Password (hesap şifresi DEĞİL)
SMTP_FROM=
APP_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Bybit ────────────────────────────────────────────────────────
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ── Telegram Alert Bot (outbound bildirimler) ────────────────────
TELEGRAM_ALERT_BOT_TOKEN=   # @BotFather'dan al → /newbot

# ── Apple Push Notification Service (iOS push) ───────────────────
# Apple Developer hesabı gerekir → Certificates, Identifiers & Profiles → Keys → "+"
# "Apple Push Notifications service (APNs)" seç → .p8 dosyası indir
# Bunlar olmadan iOS push çalışmaz (kod sessizce skip eder, alert sadece in-app/email/telegram gider).
APNS_KEY_P8=                # .p8 dosyasının tam içeriği (BEGIN/END dahil, satır sonlarını \n yap)
APNS_KEY_ID=                # 10-haneli Key ID (.p8 indirirken Apple gösterir)
APNS_TEAM_ID=               # 10-haneli Team ID (developer.apple.com → Membership)
APNS_BUNDLE_ID=app.tradingtools.terminal
APNS_ENV=sandbox            # geliştirme: sandbox  ·  App Store / TestFlight: production

# ── US Visa Slot Watcher ─────────────────────────────────────────
# Bot token icin TELEGRAM_ALERT_BOT_TOKEN kullanilir; istersen ayri token ver:
VISA_WATCHER_TELEGRAM_BOT_TOKEN=
VISA_WATCHER_TELEGRAM_CHAT_ID=
VISA_WATCHER_URL=https://www.usvisascheduling.com/
VISA_WATCHER_INTERVAL=180
# Default false: pasif izleme yapar, sayfayi yenilemez.
VISA_WATCHER_RELOAD=false
# Asagidaki regexleri ilk calistirmadan sonra sayfadaki metne gore daraltabilirsin.
VISA_WATCHER_AVAILABLE_REGEX=(?i)available appointments?|earliest available|select appointment date|choose appointment|appointment date|uygun randevu|randevu tarihi|tarih sec|tarih seç
VISA_WATCHER_UNAVAILABLE_REGEX=(?i)no appointments? (?:are )?available|there are no available appointments|no slots? available|currently no appointments|no earlier appointments|randevu bulunmamaktadir|randevu bulunmamaktadır|uygun randevu yok|bos randevu yok|boş randevu yok
VISA_WATCHER_LOGIN_REGEX=(?i)sign in|log in|login|username|password|security question|captcha|giris yap|giriş yap|oturum ac|oturum aç|kullanici adi|kullanıcı adı|sifre|şifre

# ── Telegram MTProto (haber sniper) ──────────────────────────────
TELEGRAM_API_ID=            # my.telegram.org
TELEGRAM_API_HASH=
TELEGRAM_PHONE=             # +90...
TELEGRAM_SESSION=data/tg_sniper
TELEGRAM_CHANNELS=
TELEGRAM_NEWS_PRIORITY=HIGH

TRONGRID_API_KEY=          # trongrid.io — TRON big-transfer tracker (ücretsiz, rate-limit açar)
